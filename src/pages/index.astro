---
import Layout from "../layouts/Layout.astro"
import { Image } from "astro:assets"
import familie from "../assets/familie.svg"
import gemeinsam from "../assets/gemeinsam.svg"
import uebermut from "../assets/uebermut.svg"
import logoVolksbank from "../assets/logo-volksbank-kurpfalz.png"
import logoJantz from "../assets/logo-jantz-metallbau.png"
import qrIban from "../assets/qr-iban.svg"
import qrPaypal from "../assets/qr-paypal.svg"
---

<Layout title="Startseite" wide>
  <section class="hero">
    <div class="hero-glow hero-glow--left" aria-hidden="true"></div>
    <div class="hero-glow hero-glow--right" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-layout">
        <div class="hero-panel">
          <h1>Mehr Möglichkeiten für Kinder im &bdquo;Baumhaus&ldquo;</h1>
          <p class="hero-lead">
            Wenn im Kindergarten eine gute Idee am Budget scheitert, springen
            wir ein: schnell, ehrenamtlich und transparent.
          </p>
          <div class="hero-actions">
            <a href="/anmeldung" class="btn btn--primary">
              <svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M16 19h6"></path>
                <path d="M19 16v6"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M3 21v-2a4 4 0 0 1 4-4h4"></path>
              </svg>
              <span>Mitglied werden</span>
            </a>
            <a href="#spenden" class="btn btn--secondary">
              <svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M19 7V4a1 1 0 0 0-1-1H6a2 2 0 0 0 0 4h13"></path>
                <path d="M3 7v11a2 2 0 0 0 2 2h14a1 1 0 0 0 1-1v-4"></path>
                <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"></path>
              </svg>
              <span>Direkt spenden</span>
            </a>
          </div>
          <p class="hero-proof">
            Seit 2005 kommt jeder Euro aus Beiträgen und Spenden bei den
            Kindern an&nbsp;&ndash; zuletzt fast
            <strong>10.000&nbsp;&euro;</strong> für die neue Außenspielanlage.
          </p>
        </div>
        <figure class="hero-media illu">
          <Image
            src={familie}
            alt="Elternteil und Kind gehen Hand in Hand durch den Regen"
            class="hero-image"
            loading="eager"
          />
          <figcaption>Bei jedem Wetter an ihrer Seite.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--about">
    <div class="container">
      <div class="section-head">
        <h2>Gemeinsam für unsere Kinder</h2>
      </div>
      <div class="about-grid">
        <div class="about-text">
          <p>
            Wir sind Eltern, Großeltern und Freunde des Evangelischen
            Kindergartens &bdquo;Das Baumhaus&ldquo;. Was uns verbindet: Gute
            Ideen für die Kinder sollen nicht am Geld scheitern. Also packen
            wir an&nbsp;&ndash; mit Zeit, Tatkraft und Geld.
          </p>
          <p>
            Besonders am Herzen liegen uns Projekte, die pädagogisch wertvoll
            sind, aber im regulären Etat keinen Platz finden. Genau dort
            bewirkt Ihre Unterstützung am meisten.
          </p>
          <p>
            Jeder Euro aus Beiträgen, Spenden und Festerlösen kommt den
            Kindern zugute. Wir arbeiten komplett ehrenamtlich und stimmen uns
            eng mit Leitung, Elternbeirat und Träger ab.
          </p>
          <ul class="about-points" role="list">
            <li>
              <svg
                class="lucide-icon"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="m20 6-9 9-5-5"></path>
              </svg>
              <span>Wir finanzieren konkrete Projekte, die direkt bei den Kindern ankommen.</span>
            </li>
            <li>
              <svg
                class="lucide-icon"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="m20 6-9 9-5-5"></path>
              </svg>
              <span>Wir arbeiten ehrenamtlich&nbsp;&ndash; niemand von uns verdient daran.</span>
            </li>
            <li>
              <svg
                class="lucide-icon"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path d="m20 6-9 9-5-5"></path>
              </svg>
              <span>Wir sind die offizielle Spendenstelle des Kindergartens&nbsp;&ndash; er selbst darf keine Spenden annehmen.</span>
            </li>
          </ul>
        </div>
        <figure class="about-media illu">
          <Image
            src={gemeinsam}
            alt="Zwei fröhliche Menschen machen ein Selfie"
            class="about-image"
            loading="lazy"
          />
          <figcaption>Ehrenamt, das gute Laune macht.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section section--alt section--projects">
    <div class="container">
      <article class="project-card">
        <div class="project-body">
        <h2>Fast 10.000&nbsp;&euro; für die neue Außenspielanlage</h2>
        <p class="impact-highlight">
          Mehr Klettern, mehr Toben, mehr sicheres Spielen im
          Freien&nbsp;&ndash; jeden Tag, für alle Kinder im Baumhaus.
        </p>
        <p>
          Genau dafür gibt es uns: Projekte, die den Kindern sofort etwas
          bringen&nbsp;&ndash; und die ohne Förderverein oft nicht zu stemmen
          wären.
        </p>
        <a href="/anmeldung" class="btn btn--secondary btn--small"
          >Mitglied werden</a
        >
        </div>
        <figure class="project-media illu">
          <Image
            src={uebermut}
            alt="Drei Kinder schneiden übermütig Grimassen"
            class="project-image"
            loading="lazy"
          />
          <figcaption>Mehr Platz zum Toben.</figcaption>
        </figure>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Der Vorstand</h2>
      </div>
      <p class="board-intro">
        Wir vier kümmern uns ehrenamtlich darum, dass jeder Euro gut ankommt.
        Schreiben Sie uns&nbsp;&ndash; wir antworten persönlich.
      </p>
      <ul class="board-grid" role="list">
        <li class="board-card">
          <span class="board-role">1. Vorsitzender</span>
          <span class="board-name">
            <a href="mailto:s.werner@foerderverein-baumhaus.de"
              >Sebastian Werner</a
            >
          </span>
        </li>
        <li class="board-card">
          <span class="board-role">2. Vorsitzende</span>
          <span class="board-name">
            <a href="mailto:k.ternes@foerderverein-baumhaus.de"
              >Kathrin Ternes</a
            >
          </span>
        </li>
        <li class="board-card">
          <span class="board-role">Kassenwart</span>
          <span class="board-name">
            <a href="mailto:m.sebastian@foerderverein-baumhaus.de"
              >Marion Sebastian</a
            >
          </span>
        </li>
        <li class="board-card">
          <span class="board-role">Schriftführer</span>
          <span class="board-name">
            <a href="mailto:b.goetz@foerderverein-baumhaus.de">Britta Götz</a>
          </span>
        </li>
      </ul>
      <p class="board-contact">
        <a href="mailto:info@foerderverein-baumhaus.de">Mail an den Vorstand</a
        >
      </p>
    </div>
  </section>

  <section class="section section--donate" id="spenden">
    <div class="container">
      <div class="section-head">
        <h2>Spenden &amp; Bankverbindung</h2>
      </div>
      <p class="donate-intro">
        Mit Ihrer Spende helfen Sie direkt dort, wo die Kinder jeden Tag
        spielen, lernen und wachsen. Und sie landet garantiert richtig: Der
        Kindergarten darf selbst keine Spenden annehmen&nbsp;&ndash; der
        Förderverein ist seine offizielle Spendenstelle.
      </p>
      <div class="donate-grid">
        <div class="donate-card">
          <h3>
            <svg
              class="lucide-icon"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path d="m2 10 10-6 10 6"></path>
              <path d="M4 10v8"></path>
              <path d="M20 10v8"></path>
              <path d="M8 14v4"></path>
              <path d="M12 14v4"></path>
              <path d="M16 14v4"></path>
              <path d="M2 18h20"></path>
            </svg>
            Per Überweisung
          </h3>
          <p class="donate-hint">
            Scannen Sie den Code mit Ihrer Banking-App&nbsp;&ndash; die
            Überweisung füllt sich von selbst aus. Oder nutzen Sie einfach die
            Bankverbindung darunter.
          </p>
          <Image
            src={qrIban}
            alt="QR-Code für Banküberweisung an den Förderverein"
            class="donate-qr"
            loading="lazy"
          />
          <dl class="donate-details">
            <dt>Bank</dt>
            <dd>Volksbank Kurpfalz</dd>
            <dt>IBAN</dt>
            <dd class="donate-iban">
              <span>DE29 6729 0100 0061 2265 08</span>
              <button
                type="button"
                class="iban-copy"
                data-iban="DE29672901000061226508"
                aria-live="polite"
                hidden
              >
                Kopieren
              </button>
            </dd>
            <dt>BIC</dt>
            <dd>GENODE61HD3</dd>
          </dl>
        </div>
        <div class="donate-card">
          <h3>
            <svg
              class="lucide-icon"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <rect x="2" y="5" width="20" height="14" rx="2"></rect>
              <path d="M2 10h20"></path>
            </svg>
            Per PayPal
          </h3>
          <p class="donate-hint">
            Scannen Sie den Code mit der Handykamera&nbsp;&ndash; oder klicken
            Sie direkt auf den Button.
          </p>
          <Image
            src={qrPaypal}
            alt="QR-Code für PayPal-Spende an den Förderverein"
            class="donate-qr"
            loading="lazy"
          />
          <a
            href="https://paypal.me/foerderbaumhaus"
            class="btn btn--primary btn--small"
            target="_blank"
            rel="noopener"
          >
            Via PayPal spenden
          </a>
        </div>
      </div>
      <div class="donate-more">
        <h3>Sie möchten mehr bewegen?</h3>
        <ul role="list">
          <li>
            <strong>Die Steuer hilft mit:</strong> Spenden an uns sind
            absetzbar&nbsp;&ndash; je nach Steuersatz holt Ihnen die
            Steuererklärung bis zur Hälfte zurück. Das gilt auch für
            Unternehmen und Selbstständige.
          </li>
          <li>
            <strong>Hier macht sie den Unterschied:</strong> Wir arbeiten
            komplett ehrenamtlich, nichts geht für Verwaltung drauf. Eine
            größere Spende ist bei uns schnell mal das nächste Projekt.
          </li>
          <li>
            <strong>Sichtbar in Großsachsen:</strong> Was Sie geben, sehen Sie
            wieder&nbsp;&ndash; auf dem Spielplatz, bei den Festen, im Alltag
            der Kinder.
          </li>
        </ul>
      </div>
      <div class="donate-business">
        <h3>Gutes tun&nbsp;&ndash; und genannt werden</h3>
        <p>
          Diese Unternehmen unterstützen die Kinder im
          Baumhaus&nbsp;&ndash; herzlichen Dank!
        </p>
        <ul class="donate-business-names" role="list">
          <li>
            <Image
              src={logoVolksbank}
              alt="Volksbank Kurpfalz eG"
              class="donate-business-logo"
              loading="lazy"
            />
          </li>
          <li>
            <Image
              src={logoJantz}
              alt="Jantz Metallbau GmbH"
              class="donate-business-logo donate-business-logo--hoch"
              loading="lazy"
            />
          </li>
        </ul>
        <p>
          Sie führen ein Unternehmen und möchten dazukommen? Bei
          Unternehmensspenden sagen wir gern öffentlich Danke&nbsp;&ndash; mit
          Ihrem Namen an dieser Stelle, wenn Sie das möchten. Schreiben Sie
          uns einfach an
          <a
            href="mailto:info@foerderverein-baumhaus.de?subject=Unternehmensspende"
            >info@foerderverein-baumhaus.de</a
          >.
        </p>
        <p class="donate-business-note">
          Gut zu wissen: Nennung und Logo ändern nichts an der Absetzbarkeit
          Ihrer Spende. Sie möchten mehr&nbsp;&ndash; etwa eine
          Verlinkung? Das machen wir als Sponsoring möglich, sprechen Sie
          uns an.
        </p>
      </div>
      <p class="donate-note">
        Spendenquittung? Selbstverständlich. Schreiben Sie einfach Ihre
        Adresse in den Verwendungszweck oder eine kurze Mail an
        <a href="mailto:info@foerderverein-baumhaus.de"
          >info@foerderverein-baumhaus.de</a
        >.
      </p>
    </div>
  </section>

  <section class="section section--kiga">
    <div class="container">
      <div class="section-head">
        <h2>Der Kindergarten</h2>
      </div>
      <address class="kiga-card">
        <p>
          Hönigstraße 10<br />
          69493 Hirschberg-Großsachsen
        </p>
        <ul class="kiga-contact" role="list">
          <li>
            Telefon: <a href="tel:+49620153756">06201-53756</a>
          </li>
          <li>
            E-Mail:
            <a
              href="mailto:kiga.baumhaus.hirschberg-grosssachsen@kbz.ekiba.de"
            >
              kiga.baumhaus.hirschberg-grosssachsen@kbz.ekiba.de
            </a>
          </li>
          <li>
            Web:
            <a
              href="https://www.dasbaumhaus-grosssachsen.de"
              target="_blank"
              rel="noopener"
            >
              www.dasbaumhaus-grosssachsen.de
            </a>
          </li>
        </ul>
      </address>
    </div>
  </section>

  <section class="section section--closing">
    <div class="container">
      <h2>Machen Sie mit?</h2>
      <p class="closing-lead">
        Schon ab 15&nbsp;&euro; im Jahr sind Sie dabei&nbsp;&ndash; oder Sie
        helfen mit einer Spende. Beides kommt ohne Umwege bei den Kindern an.
      </p>
      <div class="hero-actions">
        <a href="/anmeldung" class="btn btn--primary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M16 19h6"></path>
            <path d="M19 16v6"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M3 21v-2a4 4 0 0 1 4-4h4"></path>
          </svg>
          <span>Mitglied werden</span>
        </a>
        <a href="#spenden" class="btn btn--secondary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
          </svg>
          <span>Direkt spenden</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".iban-copy")
  if (btn && "clipboard" in navigator) {
    btn.hidden = false
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.iban ?? "")
        btn.textContent = "Kopiert ✓"
      } catch {
        // Clipboard nicht verfügbar: IBAN zum manuellen Kopieren markieren
        const span = btn.parentElement?.querySelector("span")
        if (span) {
          const range = document.createRange()
          range.selectNodeContents(span)
          const selection = window.getSelection()
          selection?.removeAllRanges()
          selection?.addRange(range)
          btn.textContent = "Markiert"
        }
      }
      setTimeout(() => {
        btn.textContent = "Kopieren"
      }, 2000)
    })
  }
</script>

<style is:global>
  /* ===== Homepage Layout ===== */
  .main--wide {
    flex-grow: 1;
    background:
      radial-gradient(
        90rem 36rem at -5% 2%,
        oklch(96% 0.03 142 / 0.72),
        transparent 60%
      ),
      radial-gradient(
        60rem 28rem at 98% 12%,
        oklch(97% 0.02 130 / 0.62),
        transparent 65%
      ),
      linear-gradient(to bottom, oklch(98% 0.01 145), var(--fill) 22%);
  }

  .container {
    max-inline-size: 62rem;
    margin-inline: auto;
    padding-inline: var(--space-m);
    position: relative;
    z-index: 1;
  }

  /* ===== Illustrationen: verankert statt geparkt ===== */
  .illu {
    position: relative;
    margin: 0;
    display: grid;
    gap: 0.7rem;
    justify-items: center;
  }

  .illu > img {
    position: relative;
    z-index: 1;
  }

  .illu::before {
    content: "";
    position: absolute;
    inset-inline: 18%;
    inset-block-end: 0;
    block-size: 0.9rem;
    background: radial-gradient(
      50% 50% at 50% 50%,
      oklch(40% 0.05 148 / 0.2),
      transparent 72%
    );
    z-index: 0;
  }

  .illu figcaption {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-weak);
    text-align: center;
  }

  .lucide-icon {
    inline-size: 1.05rem;
    block-size: 1.05rem;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    flex: 0 0 auto;
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    overflow: clip;
    padding-block: clamp(3.5rem, 6vw, 5rem) clamp(2.75rem, 5vw, 4rem);
  }

  .hero-glow {
    position: absolute;
    inline-size: clamp(16rem, 26vw, 24rem);
    block-size: clamp(16rem, 26vw, 24rem);
    border-radius: 50%;
    filter: blur(36px);
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-glow--left {
    inset-block-start: -15%;
    inset-inline-start: -6%;
    background: oklch(86% 0.09 148 / 0.9);
  }

  .hero-glow--right {
    inset-block-start: 0%;
    inset-inline-end: -8%;
    background: oklch(89% 0.09 92 / 0.9);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: clamp(1.4rem, 3.4vw, 3rem);
    align-items: center;
    animation: reveal-up 0.75s ease-out both;
  }

  .hero h1 {
    font-size: clamp(2.1rem, 1.1rem + 3.2vw, 3.4rem);
    color: var(--brand);
    font-weight: 700;
    margin-block-end: 0.9rem;
    letter-spacing: -0.015em;
    line-height: 1.08;
  }

  .hero-lead {
    font-size: clamp(1.075rem, 0.92rem + 0.4vw, 1.22rem);
    color: var(--text-weak);
    max-inline-size: 50ch;
    margin-inline: 0;
    margin-block-end: 1.4rem;
    line-height: 1.72;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: flex-start;
    margin-block-end: clamp(1.2rem, 3vw, 1.75rem);
  }

  .btn-icon {
    inline-size: 1.04rem;
    block-size: 1.04rem;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
    flex: 0 0 auto;
  }

  .hero-proof {
    margin: 0;
    padding-block-start: 0.4rem;
    max-inline-size: 46ch;
    color: var(--text-weak);
    line-height: 1.6;
  }

  .hero-proof strong {
    font-family: var(--font-display);
    font-variant-numeric: lining-nums;
    color: var(--brand);
    font-size: 1.15em;
  }

  .hero-media {
    justify-self: end;
    align-self: end;
    max-inline-size: 24rem;
    padding-block-end: 0.4rem;
  }

  .hero-media.illu::before {
    inset-block-end: 2.6rem;
  }

  .hero-image {
    max-inline-size: min(100%, 21rem);
    block-size: auto;
    transform: rotate(-1.5deg);
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 0.6rem;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
    min-height: 48px;
    border: 1px solid transparent;
  }

  .btn--primary {
    color: white;
    background: linear-gradient(
      160deg,
      var(--brand) 0%,
      oklch(35% 0.14 144) 100%
    );
    box-shadow:
      0 8px 18px oklch(30% 0.07 144 / 0.24),
      0 1px 0 oklch(100% 0 0 / 0.3) inset;
  }

  .btn--secondary {
    background: oklch(100% 0 0 / 0.75);
    color: var(--text-strong);
    border-color: oklch(70% 0.02 65 / 0.85);
  }

  .btn--small {
    padding: 0.625rem 1.2rem;
    font-size: 0.9375rem;
  }

  @media (hover: hover) and (pointer: fine) {
    .btn:hover {
      transform: translateY(-2px);
    }

    .btn--primary:hover {
      box-shadow:
        0 14px 26px oklch(30% 0.07 144 / 0.32),
        0 1px 0 oklch(100% 0 0 / 0.3) inset;
    }

    .btn--secondary:hover {
      border-color: var(--brand);
      color: var(--brand);
      box-shadow: 0 12px 20px oklch(25% 0.02 55 / 0.08);
    }
  }

  /* ===== Sections ===== */
  .section {
    padding-block: clamp(3.25rem, 7vw, 5rem);
    position: relative;
  }

  .section--alt {
    background:
      linear-gradient(
        to bottom,
        oklch(95.5% 0.025 148 / 0.92),
        oklch(92.5% 0.03 146 / 0.78)
      );
  }

  .section-head {
    margin-block-end: 1.4rem;
  }

  .section h2 {
    font-size: clamp(1.65rem, 0.9rem + 1.8vw, 2.2rem);
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }

